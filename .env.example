# ─── Waves Financial Backend — Environment Variables ──────────────────────────
# Copy this file to .env and fill in your values before starting the server.
# Never commit .env to git.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── Environment ────────────────────────────────────────────────────────────────
# Set to 'production' to use live Flinks data.
# Any other value uses mock bank data (safe for dev/staging).
NODE_ENV=development

# ── Flinks ─────────────────────────────────────────────────────────────────────
# Sandbox:    https://sandbox.flinks.com/v3
# Production: https://YOUR_INSTANCE.flinks.com/v3
FLINKS_BASE_URL=https://sandbox.flinks.com/v3
FLINKS_API_KEY=your_flinks_api_key_here

# ── Supabase ───────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
# Use the SERVICE ROLE key (not anon key) — this is server-side only, never expose to browser
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_API_KEY=your-service-role-key-here

# ── CRM (optional — Supabase is the primary store) ─────────────────────────────
# Your REST POST endpoint that receives the full lead payload.
# Leave blank to skip CRM posting (useful during initial testing).
CRM_ENDPOINT=https://your-crm.internal/api/leads
CRM_API_KEY=your_crm_api_key_here

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Add your Netlify URL and custom domain.
ALLOWED_ORIGINS=https://wavesfinancial.ca,https://wavesfinancials.netlify.app
